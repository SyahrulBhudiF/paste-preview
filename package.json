{
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"start": "vp dev --host 0.0.0.0",
		"alchemy:login": "vp exec alchemy login alchemy/alchemy.run.ts --configure",
		"deploy": "vp exec alchemy deploy alchemy/alchemy.run.ts",
		"destroy": "vp exec alchemy destroy alchemy/alchemy.run.ts",
		"infra:dev": "vp exec alchemy dev alchemy/alchemy.run.ts",
		"cf-typegen": "vp exec wrangler types",
		"lint": "vp exec oxlint -c .oxlintrc.json",
		"lint:fix": "vp exec oxlint -c .oxlintrc.json --fix",
		"format": "vp exec oxfmt -c .oxfmtrc.json . --write",
		"format:check": "vp exec oxfmt -c .oxfmtrc.json . --check",
		"check": "vp run format:check && vp run lint",
		"test": "vitest --config vitest.config.ts",
		"test:run": "vitest run --config vitest.config.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "latest",
		"@effect/platform-node": "4.0.0-beta.92",
		"@radix-ui/react-select": "latest",
		"@radix-ui/react-slot": "latest",
		"@tailwindcss/vite": "latest",
		"@tanstack/react-form": "latest",
		"@tanstack/react-query": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-ssr-query": "^1.167.1",
		"@tanstack/react-start": "latest",
		"@vitejs/plugin-react": "latest",
		"alchemy": "2.0.0-beta.59",
		"clsx": "latest",
		"effect": "4.0.0-beta.92",
		"github-markdown-css": "^5.9.0",
		"lucide-react": "latest",
		"nanoid": "latest",
		"react": "latest",
		"react-dom": "latest",
		"react-markdown": "latest",
		"rehype-highlight": "latest",
		"rehype-sanitize": "latest",
		"remark-gfm": "latest",
		"shiki": "^4.3.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "latest",
		"tailwindcss": "latest",
		"tw-animate-css": "latest",
		"typescript": "latest",
		"vite": "latest",
		"wrangler": "latest"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@types/react": "latest",
		"@types/react-dom": "latest",
		"husky": "latest",
		"oxfmt": "latest",
		"oxlint": "latest",
		"vite-plus": "^0.2.1",
		"vitest": "latest"
	},
	"packageManager": "pnpm@11.9.0"
}
